APP_NAME=Shipment Import Service
APP_ENV=local
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/import_service
RABBITMQ_URL=amqp://import_user:import_password@rabbitmq:5672//
UPLOAD_DIR=/app/data/uploads
UPLOAD_READ_CHUNK_SIZE_BYTES=1048576
MAX_UPLOAD_SIZE_BYTES=52428800
PROCESSING_ROW_CHUNK_SIZE=500
API_WORKERS=2
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
OUTBOX_BATCH_SIZE=100
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_STALE_TIMEOUT_SECONDS=60
OUTBOX_POLL_INTERVAL_SECONDS=1
OUTBOX_RETRY_DELAYS_SECONDS=2,4,8,16
IMPORT_MAX_ATTEMPTS=3
PROCESSING_STALE_TIMEOUT_SECONDS=300
WATCHDOG_INTERVAL_SECONDS=60
STARTUP_RECOVERY_BATCH_SIZE=100
WATCHDOG_BATCH_SIZE=100
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_ACKS_LATE=true
CELERY_TASK_REJECT_ON_WORKER_LOST=true
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
